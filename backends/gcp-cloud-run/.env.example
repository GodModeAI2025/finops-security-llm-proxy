# ============================================================
# LLM Proxy — Lokale Entwicklung
# ============================================================
# Kopiere diese Datei nach .env und fülle die Werte aus.
# In Production werden diese Werte über Secret Manager geladen.
# ============================================================

# GCP Project (für Secret Manager + Firestore)
GCP_PROJECT_ID=your-project-id

# Fallback API Keys (wenn Secret Manager nicht erreichbar)
LLM_PROXY_ANTHROPIC_KEY=sk-ant-api03-...
LLM_PROXY_OPENAI_KEY=sk-proj-...
LLM_PROXY_ADMIN_KEY=your-admin-secret-here

# Server
PORT=8080
NODE_ENV=development
