---
title: "LLM Proxy — GCP Cloud Run"
---
flowchart TB
    subgraph Clients["Clients"]
        DEV["Entwickler"]
        BOT["Agenten / Bots"]
        PARTNER["Externe Partner"]
        ELECTRON["Electron PoC App"]
    end

    subgraph CloudRun["Cloud Run Service"]
        direction TB
        subgraph SessionRoutes["Session-Management"]
            S1["POST /v1/session\nSession eröffnen"]
            S2["POST /v1/session/:id/complete\nSession beenden"]
        end

        subgraph ProxyRoute["Proxy"]
            P1["POST /v1/chat\nRequest entgegennehmen"]
            P2["Token validieren\n(Status, TTL, Budget)"]
            P3["Regeln prüfen\n(Rate-Limit, Scope)"]
            P4["API-Key auflösen"]
            P5["Request forwarden"]
            P6["Response evaluieren"]
            P7["Usage tracken\n(Firestore Transaction)"]
            P8["Auto-Revoke prüfen"]
        end

        subgraph AdminRoutes["Admin-API"]
            A1["CRUD /admin/tokens"]
            A2["POST /admin/revoke/:id"]
            A3["GET /admin/usage/:id"]
            A4["GET /admin/topics\nStats: Min/Max/Ø/P90"]
            A5["POST /admin/cleanup"]
        end

        subgraph TopicProfiler["Topic Profiler"]
            TP1["Historie laden"]
            TP2["P90 berechnen\n+ 10% Marge"]
            TP3["Limits setzen\nmax 50 Min / 50 €"]
            TP4["Stats aktualisieren\nMin/Max/Ø/Median/P90"]
        end
    end

    subgraph GCPServices["GCP Services"]
        FS[("Firestore\ntokens/{id}\ntokens/{id}/usage/current\ntopics/{topic}:{model}\nconfig/pricing")]
        SM["Secret Manager\nsk-ant-...\nsk-proj-..."]
        CS["Cloud Scheduler\nalle 5 Min"]
    end

    subgraph LLMProviders["LLM Provider"]
        ANTH["Anthropic API"]
        OAI["OpenAI API"]
        GOOG["Google AI API"]
    end

    Clients -->|"Bearer ptk_..."| P1
    Clients -->|"topic + model"| S1

    S1 --> TP1
    TP1 --> TP2
    TP2 --> TP3
    TP3 -->|"Token erstellen\nmit adaptiven Limits"| FS

    S2 --> TP4
    TP4 -->|"Messpunkt speichern\nLimits neu berechnen"| FS

    P1 --> P2
    P2 -->|"Firestore Read"| FS
    P2 --> P3
    P3 --> P4
    P4 -->|"Secret laden"| SM
    P4 --> P5
    P5 -->|"Bearer sk-ant/sk-proj"| LLMProviders
    LLMProviders -->|"Response + usage"| P6
    P6 --> P7
    P7 -->|"Atomic Increment"| FS
    P7 --> P8
    P8 -->|"Budget/TTL/Streak\nüberschritten?"| FS

    CS -->|"POST /admin/cleanup"| A5
    A5 -->|"Abgelaufene TTLs\nrevoken"| FS

    A4 -->|"Topic-Profile\nlesen"| FS

    style CloudRun fill:#E6F1FB,stroke:#185FA5,stroke-width:2px
    style GCPServices fill:#EAF3DE,stroke:#3B6D11,stroke-width:1px
    style LLMProviders fill:#F1EFE8,stroke:#888780,stroke-width:1px
    style Clients fill:#FAFAF8,stroke:#D3D1C7,stroke-width:1px
    style TopicProfiler fill:#E1F5EE,stroke:#0F6E56,stroke-width:1px
    style SessionRoutes fill:#EEEDFE,stroke:#534AB7,stroke-width:1px
